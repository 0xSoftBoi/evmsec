{
  "name": "evmsec",
  "version": "0.1.0",
  "description": "A security CLI for EVM chains. Flagship: bridge solvency — is a lock-and-mint bridge actually fully backed, or printing money?",
  "type": "module",
  "license": "MIT",
  "author": "Tsolmondorj Natsagdorj (0xSoftBoi)",
  "repository": {
    "type": "git",
    "url": "https://github.com/0xSoftBoi/evmsec.git"
  },
  "bugs": {
    "url": "https://github.com/0xSoftBoi/evmsec/issues"
  },
  "homepage": "https://github.com/0xSoftBoi/evmsec#readme",
  "publishConfig": {
    "access": "public"
  },
  "bin": {
    "evmsec": "dist/index.js",
    "evmsec-mcp": "dist/mcp.js"
  },
  "files": [
    "dist",
    "bridges.json",
    "deps.example.json",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "evmsec": "tsx src/index.ts",
    "build": "tsc -p tsconfig.build.json",
    "clean": "node -e \"require('node:fs').rmSync('dist',{recursive:true,force:true})\"",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write \"src/**/*.ts\" \"*.{json,md}\"",
    "format:check": "prettier --check \"src/**/*.ts\" \"*.{json,md}\"",
    "test": "node scripts/run-tests.mjs",
    "test:coverage": "node scripts/run-tests.mjs --experimental-test-coverage",
    "validate:registry": "tsx scripts/validate-registry.mjs",
    "gen:solc-bugs": "node scripts/gen-solc-bugs.mjs",
    "capture:fixtures": "tsx scripts/capture-fixtures.ts",
    "check": "npm run format:check && npm run lint && npm run typecheck && npm run validate:registry && npm test",
    "prepublishOnly": "npm run clean && npm run build",
    "gen:status": "node scripts/gen-status.mjs"
  },
  "keywords": [
    "ethereum",
    "evm",
    "security",
    "bridge",
    "solvency",
    "proof-of-reserves",
    "cross-chain",
    "audit"
  ],
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "dotenv": "^17.4.2",
    "ethers": "^6.13.5"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^26.0.1",
    "eslint": "^10.6.0",
    "eslint-config-prettier": "^10.1.8",
    "prettier": "^3.9.4",
    "tsx": "^4.19.2",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.62.1"
  }
}
