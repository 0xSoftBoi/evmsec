{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "npm run build",
  "outputDirectory": "public",
  "functions": {
    "api/*.mjs": {
      "maxDuration": 60,
      "memory": 1024,
      "includeFiles": "{dist/**,bridges.json}"
    }
  },
  "rewrites": [
    { "source": "/", "destination": "/api/index" },
    { "source": "/api/routes/:id/history", "destination": "/api/history?id=:id" }
  ]
}
